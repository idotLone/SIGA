<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recibo <%= recibo.numero %> | SIGA</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body { font-family: Arial, sans-serif; background: #fff; }
    .recibo-wrapper { max-width: 750px; margin: 30px auto; padding: 40px; border: 1px solid #ddd; }
    .recibo-header { border-bottom: 3px solid #0d6efd; padding-bottom: 20px; margin-bottom: 30px; }
    .recibo-titulo { font-size: 2rem; font-weight: bold; color: #0d6efd; }
    .recibo-footer { border-top: 1px solid #ddd; margin-top: 40px; padding-top: 20px; }
    .anulado-stamp {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%) rotate(-30deg);
      font-size: 4rem; font-weight: bold; color: rgba(220,53,69,0.25);
      border: 10px solid rgba(220,53,69,0.25); padding: 10px 30px;
      white-space: nowrap; pointer-events: none;
    }
    @media print {
      .no-print { display: none !important; }
      body { margin: 0; }
      .recibo-wrapper { border: none; margin: 0; padding: 20px; }
    }
  </style>
</head>
<body>

  <!-- Botão de impressão -->
  <div class="text-center mt-3 mb-2 no-print">
    <button onclick="window.print()" class="btn btn-primary me-2">
      🖨️ Imprimir
    </button>
    <a href="/financeiro/recibos/<%= recibo.id %>" class="btn btn-outline-secondary">
      ← Voltar
    </a>
  </div>

  <div class="recibo-wrapper position-relative">

    <!-- Marca de anulado (se for o caso) -->
    <% if (recibo.estado === 'anulado') { %>
    <div class="anulado-stamp">ANULADO</div>
    <% } %>

    <!-- Cabeçalho -->
    <div class="recibo-header d-flex justify-content-between align-items-start">
      <div>
        <div class="recibo-titulo">SIGA</div>
        <p class="mb-0 text-muted">Sistema de Gestão de Associados</p>
        <p class="mb-0 text-muted small">Organização Não Governamental</p>
      </div>
      <div class="text-end">
        <h3 class="fw-bold mb-1">RECIBO DE PAGAMENTO</h3>
        <p class="mb-0"><strong>Nº:</strong> <%= recibo.numero %></p>
        <p class="mb-0"><strong>Data:</strong> <%= new Date(recibo.data_emissao).toLocaleDateString('pt-PT') %></p>
      </div>
    </div>

    <!-- Dados do Associado -->
    <div class="row mb-4">
      <div class="col-7">
        <h6 class="fw-bold text-uppercase small text-muted mb-2">Emitido a:</h6>
        <% if (recibo.pagamento && recibo.pagamento.associado) {
           const ass = recibo.pagamento.associado;
           const nome = ass.tipo === 'pessoa_fisica' ? `${ass.nome} ${ass.apelido || ''}`.trim() : ass.nome_entidade;
        %>
        <p class="mb-1"><strong><%= nome %></strong></p>
        <% if (ass.nif) { %><p class="mb-1 small">NIF: <%= ass.nif %></p><% } %>
        <p class="mb-1 small"><%= ass.email %></p>
        <% if (ass.telefone) { %><p class="mb-1 small"><%= ass.telefone %></p><% } %>
        <% if (ass.morada) { %><p class="mb-0 small"><%= ass.morada %></p><% } %>
        <% } %>
      </div>
      <div class="col-5 text-end">
        <h6 class="fw-bold text-uppercase small text-muted mb-2">Dados do Pagamento:</h6>
        <% if (recibo.pagamento) { %>
        <p class="mb-1 small">Cód. Pagamento: <strong><%= recibo.pagamento.codigo %></strong></p>
        <p class="mb-1 small">Data pgto: <%= new Date(recibo.pagamento.data_pagamento).toLocaleDateString('pt-PT') %></p>
        <% const metodos = { transferencia: 'Transferência Bancária', numerario: 'Numerário', cheque: 'Cheque', mbway: 'MBWay', outro: 'Outro' }; %>
        <p class="mb-1 small">Método: <%= metodos[recibo.pagamento.metodo_pagamento] %></p>
        <% if (recibo.pagamento.referencia_pagamento) { %>
        <p class="mb-0 small">Ref: <%= recibo.pagamento.referencia_pagamento %></p>
        <% } %>
        <% } %>
      </div>
    </div>

    <!-- Tabela de itens -->
    <table class="table table-bordered mb-4">
      <thead style="background-color: #f8f9fa;">
        <tr>
          <th>Descrição</th>
          <th class="text-end" style="width: 160px;">Valor (CVE)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= recibo.descricao %></td>
          <td class="text-end fw-bold"><%= parseFloat(recibo.valor_total).toFixed(2) %></td>
        </tr>
      </tbody>
      <tfoot>
        <tr style="background-color: #f8f9fa;">
          <td class="text-end fw-bold fs-6">TOTAL</td>
          <td class="text-end fw-bold fs-5 text-success"><%= parseFloat(recibo.valor_total).toFixed(2) %> CVE</td>
        </tr>
      </tfoot>
    </table>

    <!-- Rodapé do documento -->
    <div class="recibo-footer row">
      <div class="col-6">
        <p class="mb-1 small">Emitido por: <strong><%= recibo.emissor ? recibo.emissor.nome : '—' %></strong></p>
        <p class="mb-1 small">Divisão de Gestão Financeira</p>
        <p class="mb-0 small text-muted">Documento emitido electronicamente pelo sistema SIGA.</p>
        <p class="mb-0 small text-muted">Data de emissão: <%= new Date(recibo.data_emissao).toLocaleString('pt-PT') %></p>
      </div>
      <div class="col-6 text-end d-flex flex-column align-items-end justify-content-end">
        <div style="margin-top: 40px; border-top: 1px solid #999; padding-top: 8px; min-width: 220px; text-align: center;">
          <small class="text-muted">Assinatura / Carimbo</small>
        </div>
      </div>
    </div>

  </div>

</body>
</html>
