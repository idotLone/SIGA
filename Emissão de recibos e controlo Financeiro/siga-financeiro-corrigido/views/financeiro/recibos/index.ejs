<%# views/financeiro/recibos/index.ejs %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="siga-page-title mb-1">
      <i class="bi bi-receipt text-primary me-2"></i>Recibos Emitidos
    </h2>
    <p class="text-muted mb-0">Total de <strong><%= count %></strong> recibo(s) encontrado(s)</p>
  </div>
  <a href="/financeiro" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Voltar
  </a>
</div>

<!-- Filtros -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/financeiro/recibos" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Nº Recibo</label>
        <input type="text" name="numero" class="form-control form-control-sm"
               placeholder="REC-2026-..." value="<%= filtros.numero || '' %>" />
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold">Estado</label>
        <select name="estado" class="form-select form-select-sm">
          <option value="">Todos</option>
          <option value="ativo" <%= filtros.estado === 'ativo' ? 'selected' : '' %>>Ativo</option>
          <option value="anulado" <%= filtros.estado === 'anulado' ? 'selected' : '' %>>Anulado</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold">Data início</label>
        <input type="date" name="data_inicio" class="form-control form-control-sm"
               value="<%= filtros.data_inicio || '' %>" />
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold">Data fim</label>
        <input type="date" name="data_fim" class="form-control form-control-sm"
               value="<%= filtros.data_fim || '' %>" />
      </div>
      <div class="col-md-1 d-flex gap-1">
        <button type="submit" class="btn btn-primary btn-sm w-100">
          <i class="bi bi-search"></i>
        </button>
        <a href="/financeiro/recibos" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-x"></i>
        </a>
      </div>
    </form>
  </div>
</div>

<!-- Tabela de recibos -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if (recibos.length === 0) { %>
      <div class="text-center py-5 text-muted">
        <i class="bi bi-receipt fs-1"></i>
        <p class="mt-2">Nenhum recibo encontrado.</p>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover siga-table mb-0">
          <thead>
            <tr>
              <th>Nº Recibo</th>
              <th>Associado</th>
              <th>Tipo</th>
              <th>Valor</th>
              <th>Data Emissão</th>
              <th>Emitido por</th>
              <th>Estado</th>
              <th class="text-center">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% recibos.forEach(rec => { %>
            <tr class="<%= rec.estado === 'anulado' ? 'table-secondary' : '' %>">
              <td>
                <code class="<%= rec.estado === 'anulado' ? 'text-decoration-line-through text-muted' : 'text-dark' %>">
                  <%= rec.numero %>
                </code>
              </td>
              <td>
                <% if (rec.pagamento && rec.pagamento.associado) {
                   const ass = rec.pagamento.associado;
                   const nome = ass.tipo === 'pessoa_fisica' ? `${ass.nome} ${ass.apelido || ''}`.trim() : ass.nome_entidade;
                %>
                <div class="fw-semibold"><%= nome %></div>
                <small class="text-muted"><%= ass.codigo %></small>
                <% } else { %>
                <span class="text-muted">—</span>
                <% } %>
              </td>
              <td>
                <% if (rec.pagamento) { %>
                  <% const tipoLabels = { quota: 'Quota', atividade: 'Atividade', inscricao: 'Inscrição' }; %>
                  <span class="badge bg-secondary"><%= tipoLabels[rec.pagamento.tipo] || rec.pagamento.tipo %></span>
                <% } %>
              </td>
              <td class="fw-bold"><%= parseFloat(rec.valor_total).toFixed(2) %> CVE</td>
              <td><small><%= new Date(rec.data_emissao).toLocaleDateString('pt-PT') %></small></td>
              <td><small><%= rec.emissor ? rec.emissor.nome : '—' %></small></td>
              <td>
                <span class="badge bg-<%= rec.estado === 'ativo' ? 'success' : 'secondary' %>">
                  <%= rec.estado === 'ativo' ? 'Ativo' : 'Anulado' %>
                </span>
              </td>
              <td class="text-center">
                <div class="d-flex justify-content-center gap-1">
                  <a href="/financeiro/recibos/<%= rec.id %>" class="btn btn-sm btn-outline-primary" title="Ver">
                    <i class="bi bi-eye"></i>
                  </a>
                  <% if (rec.estado === 'ativo') { %>
                  <a href="/financeiro/recibos/<%= rec.id %>/imprimir" target="_blank" class="btn btn-sm btn-outline-secondary" title="Imprimir">
                    <i class="bi bi-printer"></i>
                  </a>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Paginação -->
      <% if (totalPaginas > 1) { %>
      <div class="d-flex justify-content-between align-items-center p-3 border-top">
        <small class="text-muted">Página <%= paginaAtual %> de <%= totalPaginas %></small>
        <nav>
          <ul class="pagination pagination-sm mb-0">
            <% if (paginaAtual > 1) { %>
              <li class="page-item"><a class="page-link" href="?pagina=<%= paginaAtual - 1 %>">‹</a></li>
            <% } %>
            <% for (let p = Math.max(1, paginaAtual - 2); p <= Math.min(totalPaginas, paginaAtual + 2); p++) { %>
              <li class="page-item <%= p === paginaAtual ? 'active' : '' %>">
                <a class="page-link" href="?pagina=<%= p %>"><%= p %></a>
              </li>
            <% } %>
            <% if (paginaAtual < totalPaginas) { %>
              <li class="page-item"><a class="page-link" href="?pagina=<%= paginaAtual + 1 %>">›</a></li>
            <% } %>
          </ul>
        </nav>
      </div>
      <% } %>
    <% } %>
  </div>
</div>
