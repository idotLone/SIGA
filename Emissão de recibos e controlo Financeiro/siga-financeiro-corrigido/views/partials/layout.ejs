<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= titulo %> | SIGA</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <!-- SIGA Custom CSS -->
  <link href="/css/siga.css" rel="stylesheet" />
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark siga-navbar">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-diagram-3-fill me-2"></i>SIGA
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/associados"><i class="bi bi-people me-1"></i>Associados</a>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle active" href="#" data-bs-toggle="dropdown">
            <i class="bi bi-cash-coin me-1"></i>Financeiro
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/financeiro"><i class="bi bi-grid me-2"></i>Visão Geral</a></li>
            <li><a class="dropdown-item" href="/financeiro/pagamentos"><i class="bi bi-credit-card me-2"></i>Pagamentos</a></li>
            <li><a class="dropdown-item" href="/financeiro/recibos"><i class="bi bi-receipt me-2"></i>Recibos</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/financeiro/relatorio"><i class="bi bi-bar-chart-line me-2"></i>Relatório</a></li>
          </ul>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/atividades"><i class="bi bi-calendar-event me-1"></i>Atividades</a>
        </li>
      </ul>
      <ul class="navbar-nav ms-auto">
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            <i class="bi bi-person-circle me-1"></i>
            <%= usuario ? usuario.nome : 'Utilizador' %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><span class="dropdown-item-text small text-muted"><%= usuario ? usuario.perfilLabel || usuario.perfil : '' %></span></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Sair</a></li>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</nav>

<!-- MAIN CONTENT -->
<main class="container-fluid py-4 px-4">

  <!-- Alertas Flash -->
  <% if (locals.mensagem && mensagem.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i><%= mensagem %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (locals.erro && erro.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i><%= erro %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <%- body %>

</main>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- SIGA Custom JS -->
<script src="/js/siga.js"></script>
</body>
</html>
